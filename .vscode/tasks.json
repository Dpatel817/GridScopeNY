{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Python Backend",
      "type": "shell",
      "command": "/usr/local/bin/python3 -m uvicorn api.main:app --host 0.0.0.0 --port 8000 --reload",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "PYTHONPATH": "${workspaceFolder}/backend"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^ERROR" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Started reloader process",
          "endsPattern": "Application startup complete"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "gridscope"
      }
    },
    {
      "label": "Start React Frontend",
      "type": "shell",
      "command": "/usr/local/bin/pnpm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^ERROR" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "gridscope"
      }
    },
    {
      "label": "Start Full Stack",
      "dependsOn": ["Start Python Backend", "Start React Frontend"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}

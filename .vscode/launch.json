{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend",
      "type": "node-terminal",
      "request": "launch",
      "command": "python3 -m uvicorn api.main:app --host 0.0.0.0 --port 8000 --reload",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend"
      }
    },
    {
      "name": "Frontend",
      "type": "node-terminal",
      "request": "launch",
      "command": "/usr/local/bin/pnpm run dev",
      "cwd": "${workspaceFolder}/frontend"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["Backend", "Frontend"],
      "stopAll": true
    }
  ]
}
